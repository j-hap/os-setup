{
  // --- general ---
  "update.mode": "start",
  "update.enableWindowsBackgroundUpdates": true,
  "update.showReleaseNotes": false,
  "telemetry.telemetryLevel": "off",
  "modernFortranFormatter.fprettifyArgs": "-i 2",
  "window.title": "${dirty}${activeEditorLong}${separator}${rootName}${separator}${appName}",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "files.associations": {
    "*.tikz": "latex",
    "*.f": "fortran",
    "*.FCMacro": "python"
  },
  "git.openRepositoryInParentFolders": "always",
  // --- editor ---
  "editor.unicodeHighlight.nonBasicASCII": false,
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "editor.detectIndentation": false,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "editor.renderWhitespace": "all",
  "files.trimTrailingWhitespace": true,
  // --- extensions ---
  "json.format.keepLines": true,
  "codesnap.shutterAction": "copy",
  "redhat.telemetry.enabled": false,
  "latex-workshop.latex.recipe.default": "latexmk (lualatex)",
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.autoBuild.cleanAndRetry.enabled": false,
  "latex-workshop.latex.build.clearLog.everyRecipeStep.enabled": false,
  "latex-workshop.latex.autoBuild.run": "never",
  "[matlab]": {
    "editor.formatOnSave": false
  },
  "powershell.codeFormatting.newLineAfterCloseBrace": false,
  "evenBetterToml.formatter.allowedBlankLines": 1,
  "evenBetterToml.formatter.alignEntries": true,
  "evenBetterToml.formatter.alignComments": true,
  "evenBetterToml.formatter.columnWidth": 80,
  "evenBetterToml.formatter.indentEntries": true,
  "evenBetterToml.formatter.indentTables": true,
  "evenBetterToml.formatter.trailingNewline": true,
  "rewrap.wholeComment": false,
  "rewrap.wrappingColumn": 100,
  // --- language specific ---
  // black is too slow to run it on save
  "[python]": {
    "editor.tabSize": 4,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    },
    "justMyCode": false
  },
  "isort.args": [ "--profile", "black" ],
  "[lex]": {
    "rewrap.wrappingColumn": 80
  },
  "jupyter.debugJustMyCode": false,
  // trailing whitespace has a purpose in md
  "[markdown]": {
    "files.trimTrailingWhitespace": false,
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.unicodeHighlight.invisibleCharacters": false,
    "editor.wordWrap": "off",
    // this just generates too many popups
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },
  "[latex]": {
    // this just generates too many popups
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    },
    "rewrap.wrappingColumn": 80,
    "editor.wordWrap": "on",
    "editor.formatOnSave": false
  },
  "workbench.editorAssociations": {
    "*.pdf": "latex-workshop-pdf-hook"
  },
  "cmake.configureOnOpen": false,
  "ruff.organizeImports": false,
  "C_Cpp.clang_format_fallbackStyle": "Google",
  "recall.extraCss": [
    "{{yzhang.markdown-all-in-one}}/node_modules/katex/dist/katex.min.css"
  ],
  "diffEditor.ignoreTrimWhitespace": false,
  "terminal.integrated.inheritEnv": false,
  "latex-workshop.formatting.latex": "tex-fmt",
  "chat.agent.maxRequests": 200
}